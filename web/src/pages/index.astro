---
import Base from "@/src/layouts/Base.astro";
import { QuizList } from "@/src/components/QuizList";
import fs from "node:fs";
import path from "node:path";
import type { Quiz } from "@/src/types/quiz";

const dataDir = path.resolve("data");
const files = fs.readdirSync(dataDir).filter((f) => f.endsWith(".json"));

const quizzes = files.map((file) => {
  const id = file.replace(/\.json$/, "");
  const raw = fs.readFileSync(path.join(dataDir, file), "utf-8");
  const quiz: Quiz = JSON.parse(raw);
  const name = (quiz.frontmatter as any)?.name ?? id;
  const category = (quiz.frontmatter as any)?.category;
  const tags: string[] = (quiz.frontmatter as any)?.tags ?? [];
  const questionCount = quiz.items.filter((s) => s.question).length;
  return { id, name, category, tags, questionCount };
});
---

<Base title="Quizzes">
  <QuizList quizzes={quizzes} client:only="react" />
</Base>
