---
import "@/src/styles/global.css";
import { SettingsMenu } from "@/src/components/SettingsMenu";

interface Props {
  title?: string;
}

const { title } = Astro.props;
const pageTitle = [title, "Quizlang"].filter(Boolean).join(" | ");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="bg-bg-1 border-b border-border px-4 sm:px-6 py-3 sm:py-4 flex items-center">
      <a href={import.meta.env.BASE_URL} class="text-base sm:text-lg font-bold text-text-primary hover:text-accent">
        Quizlang
      </a>
      <div class="ml-auto">
        <SettingsMenu client:only="react" />
      </div>
    </header>
    <main class="flex-1">
      <slot />
    </main>
  </body>
</html>
