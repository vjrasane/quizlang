mk-types-dir:
  mkdir -p src/types

schema: mk-types-dir
  quiz schema > src/types/schema.json

types: schema
  npx json-schema-to-typescript src/types/schema.json --output src/types/quiz.d.ts

generate: schema
  npx tsx pipeline/index.ts

parse:
  mkdir -p data
  for f in quizzes/*.quiz; do \
    echo "Parsing $f"; \
    quiz parse "$f" > "data/$(basename "$f" .quiz).json"; \
  done

build: types generate parse
