---
import { locales, defaultLocale } from "@/src/i18n";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const storageKey = "quizlang-locale";
const localeList = Array.from(locales);
const fallback = defaultLocale;
---

<html>
  <head>
    <meta charset="utf-8" />
    <script is:inline define:vars={{ base, storageKey, localeList, fallback }}>
      function detect() {
        try {
          var stored = localStorage.getItem(storageKey);
          if (localeList.includes(stored)) return stored;
          var browser = navigator.language.split("-")[0];
          if (localeList.includes(browser)) return browser;
        } catch (error) {
          console.error("Error detecting locale:", error);
        }
        return fallback;
      }
      window.location.replace(base + "/" + detect() + "/");
    </script>
  </head>
</html>
