---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import { routes } from "@/src/routes";

export const getStaticPaths: GetStaticPaths = async () => {
  const entries = await getCollection("quizzes");
  return entries.map((entry) => {
    const fm = entry.data.frontmatter as Record<string, unknown> | undefined;
    return {
      params: { id: entry.id },
      props: { quizLanguage: (fm?.language as string) ?? null },
    };
  });
};

const { quizLanguage } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const id = Astro.params.id;

if (quizLanguage) 
  return Astro.redirect(routes.playWithLocale(id, quizLanguage))

---

<html>
  <head>
    <meta charset="utf-8" />
    <script is:inline define:vars={{ quizLanguage, base, id }}>
      var key = "quizlang-locale";
      var stored = localStorage.getItem(key);
      var browser = navigator.language.split("-")[0];
      var locale =
        quizLanguage ??
        (stored === "en" || stored === "fi" ? stored : null) ??
        (browser === "en" || browser === "fi" ? browser : null) ??
        "en";
      window.location.replace(base + "/" + locale + "/play/" + id);
    </script>
  </head>
</html>
