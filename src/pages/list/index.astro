---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<html>
  <head>
    <meta charset="utf-8" />
    <script is:inline define:vars={{ base }}>
      var key = "quizlang-locale";
      var stored = localStorage.getItem(key);
      var browser = navigator.language.split("-")[0];
      var locale =
        (stored === "en" || stored === "fi" ? stored : null) ??
        (browser === "en" || browser === "fi" ? browser : null) ??
        "en";
      window.location.replace(base + "/" + locale + "/");
    </script>
  </head>
</html>
